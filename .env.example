OPENAI_API_KEY=sk-your-key-here

FLASK_SECRET_KEY=change-me
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# Auth server (email code login)
# Firebase (replace local auth)
# Web config (Firebase Console -> Project settings -> Your apps -> SDK setup and configuration)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=

# Admin credentials for verifying ID tokens in backend.
# Option A (recommended): point to a service account JSON file.
FIREBASE_ADMIN_CREDENTIALS_PATH=
# Option B: paste the full service account JSON in one line (escape quotes if needed).
FIREBASE_ADMIN_CREDENTIALS_JSON=

# Plans / limits
FREE_DAILY_MESSAGE_LIMIT=15
# Optional; if set, daily counting uses this timezone (IANA name like Europe/Berlin).
USAGE_TZ=Europe/Berlin
# Optional; enables POST /admin/set-user-plan with header X-Admin-Token.
ADMIN_TOKEN=eslavtxaem0116

# Public base URL (recommended in production behind proxies), e.g. https://yourdomain.com
PUBLIC_BASE_URL=

# Stripe billing (Pro subscription)
STRIPE_SECRET_KEY=sk_test_51TD3rdQ2DHtyvULKVgPCfhkAUNzAkVWYe4qZlxcn7RJhWHBto97jW6CAqlaqplbP4yb8Yvi22W0KfR2duPLcy3d000xjMpF0OM
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard (Products -> your subscription product -> Pricing)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Optional extra tiers if you keep them enabled in the UI
STRIPE_PRICE_ULTIMATE_MONTHLY=
STRIPE_PRICE_ULTIMATE_YEARLY=

# Firestore billing collection (optional; defaults to billing_users)
FIRESTORE_BILLING_COLLECTION=billing_users
